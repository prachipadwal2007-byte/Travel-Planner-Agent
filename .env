 ============================================================
#  IBM watsonx.ai Credentials — copy to .env and fill in
# ============================================================

# IBM Cloud API Key (required)
IBM_API_KEY=

# IBM watsonx.ai Project ID (required)
WATSONX_PROJECT_ID=

# IBM watsonx.ai URL (default: Dallas region)
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Flask secret key (change this to a long random string in production)
FLASK_SECRET_KEY=change-me-to-a-long-random-secret

# Flask environment (development | production)
FLASK_ENV=development

# Flask port
PORT=5000
